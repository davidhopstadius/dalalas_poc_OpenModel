# Kopiera till .env och fyll i dina nycklar:  copy .env.example .env
GRUNDEN_API_KEY=din-api-nyckel-har

# ---- Leverantorsval (multi-provider) ---------------------------------------
# Aktiv LLM-leverantor: grunden (default), berget eller anthropic. Kan ocksa
# valjas live under Installningar. Den AKTIVA leverantoren maste ha en nyckel.
LLM_PROVIDER=grunden

# Berget AI (OpenAI-kompatibel, svensk/EU). Modell + pris fylls i fran din
# Berget-konsol (prislistan ligger bakom inloggning). Pris i kr per 1M tokens.
# BERGET_API_KEY=
# BERGET_MODEL=
# BERGET_BASE_URL=https://api.berget.ai/v1
# BERGET_PRICE_IN=0
# BERGET_PRICE_OUT=0

# Anthropic (Claude, Messages-API - egen adapter).
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Valfritt - standardvarden anvands om de utelamnas
GRUNDEN_BASE_URL=https://api.grunden.ai/v1
GRUNDEN_MODEL=glm-5.1

# Reasoning/thinking-lage (1 = pa, 0 = av). Pa som standard.
GRUNDEN_THINKING=1

# Timeout (sekunder) for API-anrop. Backstop sa en trog leverantor felar synligt
# i stallet for att hanga i minuter (thinking-svar ryms anda i 120 s).
GRUNDEN_TIMEOUT=120

# Web search pa/av (1 = pa, 0 = av). Pa som standard.
# Sokning sker bara om bade detta ar pa OCH BRAVE_API_KEY ar satt.
GRUNDEN_SEARCH=1

# Brave Search API-nyckel. Kravs for att sokning ska fungera.
BRAVE_API_KEY=

# Embeddings-backend for dokumentsokning (RAG):
#   local   = fastembed, kors i processen (oberoende av Grundens embeddings-uptime)
#   grunden = Grundens API (bge-m3)
# Byt lokal modell med GRUNDEN_LOCAL_EMBED_MODEL (default intfloat/multilingual-e5-large).
# OBS: index och fragor maste anvanda samma modell - kor om `python ingest.py` vid byte.
GRUNDEN_EMBED_BACKEND=local

# Reranking (Steg 2): BGE cross-encoder som omsorterar dense-traffarna.
# 1 = pa (standard), 0 = av. Kan ocksa slas av/pa live i chatten med /rerank.
GRUNDEN_RERANK=1
# Rerank-backend: local (fastembed cross-encoder, oberoende av Grundens uptime)
# eller grunden (API). Lokalt kraver INGEN omindexering. Byt modell med
# GRUNDEN_LOCAL_RERANK_MODEL (default jinaai/jina-reranker-v2-base-multilingual).
GRUNDEN_RERANK_BACKEND=local
# GRUNDEN_RERANK_MODEL=bge-reranker-v2-m3
# RAG_RERANK_CANDIDATES=20   # antal dense-traffar som skickas till rerankern

# Valfri systemprompt. Om tom anvands en standardprompt med dagens datum.
# GRUNDEN_SYSTEM_PROMPT=Du ar en hjalpsam assistent som svarar pa svenska.
