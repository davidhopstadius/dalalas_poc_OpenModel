# Kopiera till .env och fyll i dina nycklar:  copy .env.example .env
GRUNDEN_API_KEY=din-api-nyckel-har

# Valfritt - standardvarden anvands om de utelamnas
GRUNDEN_BASE_URL=https://api.grunden.ai/v1
GRUNDEN_MODEL=glm-5.1

# Reasoning/thinking-lage (1 = pa, 0 = av). Pa som standard.
GRUNDEN_THINKING=1

# Web search via Brave Search API. Lamna tom for att stanga av sokning.
BRAVE_API_KEY=

# Valfri systemprompt. Om tom anvands en standardprompt med dagens datum.
# GRUNDEN_SYSTEM_PROMPT=Du ar en hjalpsam assistent som svarar pa svenska.
